// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//======= tabel kkn bidan ============

model Pasien {
  id           Int         @id @default(autoincrement())
  nama         String
  tanggalLahir String      
  alamat       String
  transaksi    Transaksi[] 
}

model Transaksi {
  id           Int      @id @default(autoincrement())
  tanggal      DateTime @default(now())
  pasienId     Int
  pasien       Pasien   @relation(fields: [pasienId], references: [id])
  terapi       String   // hamil, persalinan, kb, imunisasi, komplementer, umum
  pembayaran   String   // tunai, qris, tf
  totalHarga   Float    @default(0)
}