// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ==========================================
// 1. DATA PASIEN
// ==========================================
model Pasien {
  id           Int         @id @default(autoincrement())
  nama         String      @db.VarChar(100)
  tanggalLahir DateTime?   @db.Date
  alamat       String?     @db.Text
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  transaksi    Transaksi[]

  @@map("pasien")
}

// ==========================================
// 2. TABEL KATEGORI TERAPI (Dinamis untuk CRUD Bidan)
// ==========================================
model KategoriTerapi {
  id        Int      @id @default(autoincrement())
  nama      String   @unique @db.VarChar(100)
  deskripsi String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  terapi    Terapi[]

  @@map("kategori_terapi")
}

// ==========================================
// 3. MASTER DATA TERAPI (Katalog Layanan & Harga)
// ==========================================
model Terapi {
  id              Int               @id @default(autoincrement())
  nama            String            @db.VarChar(100)
  kategoriId      Int
  kategori        KategoriTerapi    @relation(fields: [kategoriId], references: [id], onDelete: Restrict)
  harga           Int               // Harga jual ke pasien
  hargaPokok      Int               // Modal/HPP bidan untuk layanan ini
  deskripsi       String?           @db.Text
  aktif           Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  detailTransaksi DetailTransaksi[]

  @@map("terapi")
}

// ==========================================
// 4. TABEL METODE PEMBAYARAN (Dinamis untuk CRUD Rekening/E-wallet)
// ==========================================
model MetodePembayaran {
  id        Int         @id @default(autoincrement())
  nama      String      @unique @db.VarChar(50)
  aktif     Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  transaksi Transaksi[]

  @@map("metode_pembayaran")
}

// ==========================================
// 5. TRANSAKSI (Invoice POS Header - Hanya Create & Read)
// ==========================================
model Transaksi {
  id                 Int               @id @default(autoincrement())
  nomorInvoice       String            @unique @db.VarChar(50)
  tanggal            DateTime          @default(now())
  pasienId           Int
  pasien             Pasien            @relation(fields: [pasienId], references: [id], onDelete: Restrict)
  totalHarga         Int               // Total tagihan
  metodePembayaranId Int
  metodePembayaran   MetodePembayaran  @relation(fields: [metodePembayaranId], references: [id], onDelete: Restrict)
  catatan            String?           @db.Text
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  detailTransaksi    DetailTransaksi[]

  @@map("transaksi")
}

// ==========================================
// 6. DETAIL TRANSAKSI (Invoice POS Items Line - Hanya Create & Read)
// ==========================================
model DetailTransaksi {
  id          Int        @id @default(autoincrement())
  transaksiId Int
  transaksi   Transaksi  @relation(fields: [transaksiId], references: [id], onDelete: Cascade)
  terapiId    Int?                                                                              // Nullable: null = item manual/ad-hoc
  terapi      Terapi?    @relation(fields: [terapiId], references: [id], onDelete: Restrict)   // Optional relation
  namaManual  String?    @db.VarChar(200)                                                      // Nama item manual (diisi jika terapiId null)
  hargaJual   Int        // Snapshot harga jual saat transaksi (bisa override dari katalog)
  hargaPokok  Int        @default(0) // Snapshot harga modal (0 untuk item manual/ad-hoc)
  jumlah      Int        @default(1)
  subtotal    Int        // hargaJual * jumlah

  @@map("detail_transaksi")
}

// ==========================================
// 7. USER / AKUN PENGGUNA
// ==========================================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255) // Hashed password
  nama      String   @db.VarChar(100)
  role      String   @default("BIDAN") // BIDAN atau STAF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user")
}


