# =========================================================================
# SI-KABID - Environment Variables Template
# =========================================================================
# Salin berkas ini ke '.env' (cp .env.example .env) kemudian sesuaikan nilainya.
# Berkas '.env' berisi data rahasia dan tidak akan di-commit ke Git.

# 1. URL Koneksi Database MySQL (Prisma)
# Format: mysql://[username]:[password]@localhost:[port]/[nama_database]
# Default XAMPP/Laragon (tanpa password): mysql://root:@localhost:3306/db_kkn_bidan
DATABASE_URL="mysql://username:password@localhost:3306/db_kkn_bidan"
